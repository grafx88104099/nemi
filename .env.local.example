# ── Supabase ──────────────────────────────────────────────
# Local dev (supabase start гүйцэтгэсний дараа CLI хэвлэнэ):
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Зөвхөн серверт (Edge Function / Server Action) — браузерт хэзээ ч бүү ил гарга:
SUPABASE_SERVICE_ROLE_KEY=

# ── AI үнэлгээ (Phase 9) ──────────────────────────────────
ANTHROPIC_API_KEY=
# эсвэл OPENAI_API_KEY=

# ── Төлбөр: QPay (Phase 10) ───────────────────────────────
QPAY_USERNAME=
QPAY_PASSWORD=
QPAY_INVOICE_CODE=

# ── Газрын зураг (Phase 11) ───────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Resend (имэйл — агент урих, мэдэгдэл) ─────────────────
# ЧУХАЛ: onboarding@resend.dev нь ЗӨВХӨН Resend бүртгэлийн эзний имэйл рүү
# илгээдэг (тест). Бодит агентуудад урилга очихын тулд resend.com/domains-д
# домэйн (ж: nemi.mn) verify хийж, RESEND_FROM-ийг тэр домэйнтэй болгоно:
#   RESEND_FROM=Нэми <noreply@nemi.mn>
RESEND_API_KEY=
RESEND_FROM=Nemi <onboarding@resend.dev>
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OAuth (Supabase dashboard-д тохируулна, эндээс лавлагаа) ─
# Google / Facebook client id, secret-ийг Supabase Auth тохиргоонд оруулна.

# Google Maps (console.cloud.google.com → Maps JavaScript API + Map ID)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
